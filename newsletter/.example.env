# -------------------------------------------------------
# Kids News Newsletter — Required Environment Variables
# -------------------------------------------------------
# Copy this file to .env and fill in your own values.
# Never commit .env to version control.
# -------------------------------------------------------

# NewsAPI — get your key at https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# Anthropic — get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# SendGrid — get your key at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your_sendgrid_api_key_here

# The verified sender email address configured in SendGrid
SENDER_EMAIL=you@example.com

# Comma-separated list of recipient emails (used by standard_newsletter.py and main.py)
RECIPIENT_EMAILS=recipient1@example.com,recipient2@example.com

# Firebase service account JSON (paste the entire JSON as a single line)
# Download from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Controls whether the newsletter email is sent after processing articles.
# Set to "true" for the morning run (sends email), "false" for the evening run (saves articles only).
# Defaults to "true" if not set.
IS_NEWSLETTER_RUN=true
